{
  "name": "@pi-base/viewer",
  "private": true,
  "version": "1.0.0",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "build": "vite build --logLevel warn",
    "cf:deploy:topology": "wrangler deploy --env topology",
    "cf:deploy:graphs": "wrangler deploy --env graphs",
    "cf:preview:topology": "wrangler versions upload --env topology",
    "cf:preview:graphs": "wrangler versions upload --env graphs",
    "cy:open": "cypress open",
    "cy:open:pages": "CYPRESS_ENV=pages cypress open",
    "cy:open:workers": "CYPRESS_ENV=workers cypress open",
    "cy:run": "cypress run",
    "cy:run:pages": "CYPRESS_ENV=pages cypress run",
    "cy:run:workers": "CYPRESS_ENV=workers cypress run",
    "cy:run:preview": "CYPRESS_ENV=preview cypress run",
    "cy:run:graphs": "CYPRESS_ENV=graphs cypress run",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "tsc": "tsc --noEmit",
    "validate": "svelte-check"
  },
  "dependencies": {
    "@pi-base/core": "workspace:*",
    "@sentry/browser": "^7.93.0",
    "bootstrap": "^4.6.2",
    "d3": "^7.9.0",
    "d3-graphviz": "^5.6.0",
    "debug": "^4.4.3",
    "fromnow": "^3.0.1",
    "fuse.js": "^6.6.2",
    "hast-to-hyperscript": "^10.0.3",
    "hyperscript": "^2.0.2",
    "jquery": "^3.7.1",
    "rehype-katex": "^6.0.3",
    "remark-rehype": "^10.1.0",
    "unified": "^10.1.2",
    "unist-util-is": "^5.2.1",
    "unist-util-visit": "^4.1.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260627.1",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@tsconfig/svelte": "^3.0.0",
    "@types/debug": "^4.1.13",
    "@types/hyperscript": "0.0.7",
    "@types/katex": "^0.16.8",
    "@types/page": "^1.11.9",
    "@types/unist": "^2.0.10",
    "cypress": "^15.18.0",
    "svelte": "^4.2.20",
    "svelte-check": "^3.6.3",
    "svelte-preprocess": "^5.1.3",
    "tslib": "^2.8.1",
    "wrangler": "^4.0.0"
  }
}